# Banco PostgreSQL usado pelo Prisma.
DATABASE_URL="postgresql://usuario:senha@localhost:5432/obsidian_parfums?schema=public"

# Mercado Pago.
MERCADO_PAGO_PUBLIC_KEY=""
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=""
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_CLIENT_ID=""
MERCADO_PAGO_CLIENT_SECRET=""
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# SMTP para envio da notinha por e-mail.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Obsidian Parfums <no-reply@obsidianparfums.com.br>"

# Melhor Envio para cálculo de frete.
MELHOR_ENVIO_TOKEN=""
MELHOR_ENVIO_API_URL="https://www.melhorenvio.com.br"
MELHOR_ENVIO_USER_AGENT="Obsidian Parfums (contato@obsidianparfums.site)"
MELHOR_ENVIO_ORIGIN_ZIP=""
MELHOR_ENVIO_ORIGIN_CITY="Vitória da Conquista"
MELHOR_ENVIO_ORIGIN_STATE="BA"
MELHOR_ENVIO_PACKAGE_WIDTH="12"
MELHOR_ENVIO_PACKAGE_HEIGHT="4"
MELHOR_ENVIO_PACKAGE_LENGTH="16"
MELHOR_ENVIO_PACKAGE_WEIGHT="0.3"
